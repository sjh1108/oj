# Production env file for the algoj Lightsail box.
# Place at /opt/algoj/.env (chmod 600). Loaded by both:
#   - systemd unit (algoj-api.service) for Spring Boot
#   - docker-compose.yml for MySQL
#
# Generate strong values before deploy:
#   openssl rand -base64 24   → DB_PASSWORD, MYSQL_ROOT_PASSWORD
#   openssl rand -base64 48   → JWT_SECRET (≥ 32 chars for HS512)

# ─── Database (Spring + MySQL container) ─────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=algoj
DB_USER=algoj
DB_PASSWORD=__GENERATE__
MYSQL_ROOT_PASSWORD=__GENERATE__

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=__GENERATE__
JWT_ACCESS_TTL_MS=3600000
JWT_REFRESH_TTL_MS=604800000

# ─── Judge0 (same box, container-to-host on 2358) ────────────
JUDGE0_URL=http://localhost:2358

# ─── CORS ────────────────────────────────────────────────────
# Add Vercel domain after frontend deploy.
# Multiple origins: comma-separated.
CORS_ALLOWED_ORIGINS=https://algoj.duckdns.org,https://__YOUR_VERCEL_DOMAIN__.vercel.app

# ─── Server / profile ────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
