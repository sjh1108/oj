# Discord bot environment template. Copy to .env and fill in.

# ─── Discord application (Developer Portal) ──────────────────
# Bot token (Bot → Reset Token)
DISCORD_TOKEN=
# Application (client) ID (General Information → Application ID)
DISCORD_CLIENT_ID=
# Your Discord server (guild) ID — enable Developer Mode, right-click server → Copy Server ID
DISCORD_GUILD_ID=

# ─── OJ backend ──────────────────────────────────────────────
# Where the bot reaches the backend. Same box: http://localhost:8080
OJ_API_BASE_URL=http://localhost:8080
# Must equal the backend's BOT_API_KEY.
BOT_API_KEY=

# Public FRONTEND (Vercel) URL shown to members for changing their password.
# This is the web app where /account lives — NOT the API domain
# (algoj.duckdns.org). Pointing this at the API domain makes the link render a
# JSON 401 auth error instead of the account page.
OJ_WEB_BASE_URL=https://__YOUR_VERCEL_DOMAIN__.vercel.app
