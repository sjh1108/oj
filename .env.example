# Backend environment template.
# Copy to `.env.dev` (local dev) or `.env` (production) and fill in real values.
# Never commit `.env` or `.env.dev` — only this template lives in git.

# ═══ Required (no defaults — Spring fails to start without them) ═══

# Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=oj_dev
DB_USER=oj_user
DB_PASSWORD=replace-me

# JWT (must be ≥ 32 ASCII chars / 256 bits for HS512)
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-secure-random-256bit-secret

# Judge0
# Local dev (SSH tunnel): http://localhost:2358
# Production (same host docker): http://localhost:2358
JUDGE0_URL=http://localhost:2358

# CORS (comma-separated)
# Dev: http://localhost:3000
# Prod: https://<your-frontend-domain>
CORS_ALLOWED_ORIGINS=http://localhost:3000

# RabbitMQ (judge queue)
# Dev: compose default guest/guest works out of the box.
# Prod: set real credentials — compose passes them to the broker, the API reads
# the same vars. deploy-api.sh overrides RABBITMQ_HOST=rabbitmq in-container.
# Generate password with: openssl rand -base64 24
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ═══ Discord bot (only if running the Discord integration) ═══

# Shared secret the bot sends in X-Bot-Api-Key for /api/internal/**.
# Must match the bot's BOT_API_KEY. Generate with: openssl rand -base64 32
# Leave unset to disable bot endpoints (they fail closed).
# BOT_API_KEY=
# DISCORD_LINK_CODE_TTL_SECONDS=600

# Channel for automatic deploy announcements (/서버상태 works without this).
# Discord: 설정 → 고급 → 개발자 모드 ON → 채널 우클릭 → "채널 ID 복사"
# Leave unset to disable announcements.
# DISCORD_ANNOUNCE_CHANNEL_ID=
# ANNOUNCE_PORT=3910                  # loopback port the CD deploy pokes

# ═══ Optional (defaults shown commented) ═══

# SPRING_PROFILES_ACTIVE=dev          # dev | prod
# SERVER_PORT=8080
# JWT_ACCESS_TTL_MS=3600000           # 1h
# JWT_REFRESH_TTL_MS=604800000        # 7d
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# JUDGE_WORKER_CONCURRENCY=2          # parallel judge workers per API instance
# JUDGE_WORKER_MAX_CONCURRENCY=4

# Auto-seed admin/admin1234 on startup. Dev: true. Prod: NEVER true.
# ALGOJ_SEED_ADMIN=false
